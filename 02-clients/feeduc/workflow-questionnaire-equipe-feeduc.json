{
  "name": "Questionnaire Équipe FEEDUC → Notion + Email",
  "nodes": [
    {
      "parameters": {
        "path": "questionnaire-equipe-feeduc",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [260, 300],
      "webhookId": "questionnaire-equipe-feeduc"
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "create",
        "databaseId": {
          "__rl": true,
          "value": "VOTRE_DATABASE_NOTION_ID",
          "mode": "id"
        },
        "title": "={{ \"Réponse #\" + $now.toFormat('dd/MM HH:mm') }}",
        "propertiesUi": {
          "propertyValues": [
            {
              "key": "Date|date",
              "dateValue": "={{ $json._date_envoi }}"
            },
            {
              "key": "Outils utilisés|richText",
              "textValue": "={{ Array.isArray($json.q1) ? $json.q1.join(', ') : ($json.q1 || '') }}"
            },
            {
              "key": "Fréquence CR|select",
              "selectValue": "={{ $json.q2 || '' }}"
            },
            {
              "key": "Temps gagné|select",
              "selectValue": "={{ $json.q3 || '' }}"
            },
            {
              "key": "Niveau numérique|select",
              "selectValue": "={{ $json.q11 || '' }}"
            },
            {
              "key": "Bugs signalés|select",
              "selectValue": "={{ $json.q7 || '' }}"
            }
          ]
        }
      },
      "id": "notion-create-1",
      "name": "Notion — Créer réponse",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [520, 300],
      "credentials": {
        "notionApi": {
          "id": "VOTRE_CREDENTIAL_NOTION_ID",
          "name": "Notion API"
        }
      }
    },
    {
      "parameters": {
        "resource": "block",
        "operation": "append",
        "blockId": "={{ $json.id }}",
        "blockUi": {
          "blockValues": [
            {
              "type": "heading_2",
              "textContent": "Ce qui fonctionne bien"
            },
            {
              "type": "paragraph",
              "textContent": "={{ $('Webhook').item.json.q4 || '(pas de réponse)' }}"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Outil ayant rendu service : ' + ($('Webhook').item.json.q5 || '(pas de réponse)') }}"
            },
            {
              "type": "heading_2",
              "textContent": "Ce qui coince"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Outils peu/pas utilisés : ' + ($('Webhook').item.json.q6 || '(pas de réponse)') }}"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Bugs : ' + ($('Webhook').item.json.q7 || '(pas de réponse)') + ($('Webhook').item.json.q7_detail ? ' — ' + $('Webhook').item.json.q7_detail : '') }}"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Tâches répétitives à automatiser : ' + ($('Webhook').item.json.q8 || '(pas de réponse)') }}"
            },
            {
              "type": "heading_2",
              "textContent": "Souhaits & améliorations"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Amélioration souhaitée : ' + ($('Webhook').item.json.q9 || '(pas de réponse)') }}"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Idées d\\'automatisations : ' + ($('Webhook').item.json.q10 || '(pas de réponse)') }}"
            },
            {
              "type": "heading_2",
              "textContent": "Pour aller plus loin (Q12)"
            },
            {
              "type": "paragraph",
              "textContent": "={{ 'Sujets à creuser : ' + ($('Webhook').item.json.q12 || '(pas de réponse)') }}"
            }
          ]
        }
      },
      "id": "notion-append-1",
      "name": "Notion — Détail réponse",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [780, 300],
      "credentials": {
        "notionApi": {
          "id": "VOTRE_CREDENTIAL_NOTION_ID",
          "name": "Notion API"
        }
      }
    },
    {
      "parameters": {
        "sendTo": "catherine@csbusiness.fr",
        "subject": "={{ '📋 Nouvelle réponse questionnaire FEEDUC (IA & outils) — ' + $('Webhook').item.json._date_envoi.substr(0,10) }}",
        "message": "={{ '<b>Nouvelle réponse reçue — Questionnaire équipe FEEDUC (IA &amp; automatisation)</b><br><br><b>Usages cochés (Q1) :</b> ' + (Array.isArray($('Webhook').item.json.q1) ? $('Webhook').item.json.q1.join(', ') : ($('Webhook').item.json.q1 || 'non renseigné')) + '<br><b>Fréquence CR :</b> ' + ($('Webhook').item.json.q2 || 'non renseigné') + '<br><b>Temps gagné :</b> ' + ($('Webhook').item.json.q3 || 'non renseigné') + '<br><b>Bugs signalés :</b> ' + ($('Webhook').item.json.q7 || 'non renseigné') + ($('Webhook').item.json.q7_detail ? ' — ' + $('Webhook').item.json.q7_detail : '') + '<br><b>Niveau numérique :</b> ' + ($('Webhook').item.json.q11 || 'non renseigné') + '<br><br><b>Ce qui fonctionne :</b><br>' + ($('Webhook').item.json.q4 || '—') + '<br><br><b>Tâches à automatiser :</b><br>' + ($('Webhook').item.json.q8 || '—') + '<br><br><b>Amélioration souhaitée :</b><br>' + ($('Webhook').item.json.q9 || '—') + '<br><br><b>Sujets à creuser (Q12) :</b><br>' + ($('Webhook').item.json.q12 || '—') + '<br><br>👉 <a href=\"https://www.notion.so/' + $json.id.replace(/-/g, '') + '\">Voir la fiche complète dans Notion</a>' }}",
        "options": {}
      },
      "id": "gmail-1",
      "name": "Gmail — Notification Catherine",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1040, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "VOTRE_CREDENTIAL_GMAIL_ID",
          "name": "Gmail OAuth2"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ {\"status\": \"ok\"} }",
        "options": {}
      },
      "id": "respond-1",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1280, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Notion — Créer réponse",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notion — Créer réponse": {
      "main": [
        [
          {
            "node": "Notion — Détail réponse",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notion — Détail réponse": {
      "main": [
        [
          {
            "node": "Gmail — Notification Catherine",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gmail — Notification Catherine": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "feeduc"
    },
    {
      "name": "questionnaire"
    }
  ]
}
