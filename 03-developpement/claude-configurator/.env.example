# Supabase Configuration (placeholders only)
# Values come from 1Password item: Claude Configurator - Supabase - Prod
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration (placeholders only)
# Values come from 1Password item: Claude Configurator - Stripe - Prod
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_ID=your_stripe_price_id

# Anthropic Configuration (placeholders only)
# Value comes from 1Password item: Claude Configurator - Anthropic - Prod
ANTHROPIC_API_KEY=your_anthropic_api_key

# Application URLs
APP_URL=http://localhost:3000

# Development Mode
DEBUG=true

# Edge Functions — set via Supabase Dashboard → Edge Functions → Secrets (or `supabase secrets set`)
# SKIP_PAYMENT_CHECK=true          # QA only: bypass paiement sur chat + generate-config (retirer en prod)
# CONFIGURATOR_DEV_KEY=...         # Header X-Configurator-Dev-Key pour bypass paiement sans exposer env publique
# DEV_LOGIN_PASSWORD=...         # Mot de passe pour dev-mint-token (création / sync utilisateur test)
