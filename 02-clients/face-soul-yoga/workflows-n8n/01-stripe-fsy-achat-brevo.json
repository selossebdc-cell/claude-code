{
  "name": "FSY — Stripe Achat FSY Studio → Brevo",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "stripe-fsy-achat",
        "responseMode": "onReceived",
        "responseData": "allEntries"
      },
      "id": "webhook-stripe",
      "name": "Webhook Stripe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "stripe-fsy-achat"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.type }}",
              "value2": "checkout.session.completed"
            }
          ]
        }
      },
      "id": "filter-event",
      "name": "Filter: checkout.session.completed",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [470, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extraire les données du payload Stripe\nconst event = $input.first().json;\nconst session = event.data?.object || event;\n\nconst email = session.customer_email || session.customer_details?.email || '';\nconst name = session.customer_details?.name || '';\nconst amount = session.amount_total / 100; // centimes → euros\n\n// Déterminer l'offre selon le montant\nlet offre = 'fsy_studio';\nif (amount >= 2500) offre = 'mtm';\nelse if (amount >= 300) offre = 'sommeil_joie';\n\n// Séparer prénom / nom\nconst parts = name.split(' ');\nconst prenom = parts[0] || '';\nconst nom = parts.slice(1).join(' ') || '';\n\nreturn [{\n  json: {\n    email,\n    prenom,\n    nom,\n    offre,\n    amount,\n    date_achat: new Date().toISOString().split('T')[0],\n    stripe_customer_id: session.customer || '',\n    stripe_session_id: session.id || ''\n  }\n}];"
      },
      "id": "extract-data",
      "name": "Extraire données Stripe",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/contacts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "api-key", "value": "={{ $credentials.httpHeaderAuth.value }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"email\": \"{{ $json.email }}\",\n  \"attributes\": {\n    \"PRENOM\": \"{{ $json.prenom }}\",\n    \"NOM\": \"{{ $json.nom }}\",\n    \"OFFRE\": \"{{ $json.offre }}\",\n    \"DATE_ACHAT\": \"{{ $json.date_achat }}\",\n    \"STATUT_MEMBRE\": \"active\"\n  },\n  \"listIds\": [12],\n  \"updateEnabled\": true\n}",
        "options": {}
      },
      "id": "brevo-update",
      "name": "Brevo: Update contact → active",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [910, 200],
      "notesInFlow": true,
      "notes": "Ajoute à liste Active Members (#12) + met à jour OFFRE, DATE_ACHAT, STATUT_MEMBRE"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.brevo.com/v3/contacts/lists/11/contacts/remove",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "api-key", "value": "={{ $credentials.httpHeaderAuth.value }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"emails\": [\"{{ $json.email }}\"]\n}",
        "options": { "ignore404": true }
      },
      "id": "brevo-remove-trial",
      "name": "Brevo: Retirer de Free Trial (#11)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1130, 200]
    }
  ],
  "connections": {
    "Webhook Stripe": {
      "main": [[ { "node": "Filter: checkout.session.completed", "type": "main", "index": 0 } ]]
    },
    "Filter: checkout.session.completed": {
      "main": [
        [ { "node": "Extraire données Stripe", "type": "main", "index": 0 } ],
        []
      ]
    },
    "Extraire données Stripe": {
      "main": [[ { "node": "Brevo: Update contact → active", "type": "main", "index": 0 } ]]
    },
    "Brevo: Update contact → active": {
      "main": [[ { "node": "Brevo: Retirer de Free Trial (#11)", "type": "main", "index": 0 } ]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Quand Stripe confirme un achat FSY Studio → met à jour le contact Brevo (STATUT=active, OFFRE, DATE_ACHAT) + ajoute à Active Members + retire de Free Trial.\n\nCONFIG REQUISE :\n- Credential HTTP Header Auth avec la clé API Brevo\n- URL webhook à copier dans Stripe Dashboard → Developers → Webhooks\n- Événement Stripe : checkout.session.completed"
  }
}
