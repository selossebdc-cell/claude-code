{
  "name": "FSY — Circle Nouveau Membre → Brevo sync",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "circle-fsy-member",
        "responseMode": "onReceived"
      },
      "id": "webhook-circle",
      "name": "Webhook Circle",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "circle-fsy-member"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event_type }}",
              "value2": "member.created"
            }
          ]
        }
      },
      "id": "filter-member-created",
      "name": "Filter: member.created",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [470, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst member = data.member || data.data || data;\n\nreturn [{\n  json: {\n    email: member.email || '',\n    circle_id: String(member.id || ''),\n    name: member.name || '',\n    space_group: member.space_group_name || '',\n    created_at: member.created_at || new Date().toISOString()\n  }\n}];"
      },
      "id": "extract-circle",
      "name": "Extraire données membre Circle",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/contacts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "api-key", "value": "={{ $credentials.httpHeaderAuth.value }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"email\": \"{{ $json.email }}\",\n  \"attributes\": {\n    \"CIRCLE_ID\": \"{{ $json.circle_id }}\",\n    \"STATUT_MEMBRE\": \"active\"\n  },\n  \"updateEnabled\": true\n}",
        "options": {}
      },
      "id": "brevo-sync-circle",
      "name": "Brevo: Sync CIRCLE_ID",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [910, 300],
      "notesInFlow": true,
      "notes": "Synchronise le CIRCLE_ID dans Brevo pour pouvoir tracker l'activité Circle"
    }
  ],
  "connections": {
    "Webhook Circle": {
      "main": [[ { "node": "Filter: member.created", "type": "main", "index": 0 } ]]
    },
    "Filter: member.created": {
      "main": [
        [ { "node": "Extraire données membre Circle", "type": "main", "index": 0 } ],
        []
      ]
    },
    "Extraire données membre Circle": {
      "main": [[ { "node": "Brevo: Sync CIRCLE_ID", "type": "main", "index": 0 } ]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "description": "Quand Circle crée un nouveau membre → synchronise le CIRCLE_ID dans Brevo et confirme STATUT=active.\n\nCONFIG REQUISE :\n- Credential HTTP Header Auth avec clé API Brevo\n- Dans Circle : Settings → Developers → Webhooks → Add\n  → URL : URL webhook n8n\n  → Events : member.created"
  }
}
